library(tidyverse)
library(gtsummary)
# IMPORTANT: skip = 7 for THIS file
tri <- readr::read_csv("TRI-CRM-TRAININGS.csv", skip = 7, show_col_types = FALSE)
# Standardize names (optional but keeps your code consistent)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
# Clean + ensure active_users is numeric
tri <- tri %>%
filter(device != "Total") %>%
mutate(
step = factor(step),
device = factor(device),
active_users = as.integer(active_users)
) %>%
filter(!is.na(active_users), active_users > 0)
# Expand rows using weights so older gtsummary works
tri2 <- tri %>%
filter(step != "4. Click Training") %>%
tidyr::uncount(weights = active_users)
# Cross-tab + association test (Fisher is best if small counts like tablet)
tri2 %>%
select(step, device) %>%
tbl_cross(row = step, col = device, percent = "row") %>%
add_p(test = "fisher.test")
