library(tidyverse)
library(gtsummary)
tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6, show_col_types = FALSE)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
tri <- tri %>%
slice(-1) %>%
filter(device != "Total") %>%
mutate(
step = as.factor(step),
device = as.factor(device),
active_users = readr::parse_number(active_users)
)
tri2 <- tri %>%
filter(step != "4. Click Training") %>%
filter(!is.na(active_users), active_users > 0) %>%
tidyr::uncount(weights = active_users)
tri2 %>%
select(step, device) %>%
tbl_cross(row = step, col = device, percent = "row") %>%
add_p(test = "chisq.test")
