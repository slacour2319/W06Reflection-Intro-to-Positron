library(tidyverse)
library(gtsummary)
tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6, show_col_types = FALSE)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
tri <- tri %>%
slice(-1) %>%
filter(device != "Total") %>%
mutate(
active_users = readr::parse_number(active_users),  # safer than as.numeric()
step = as.factor(step),
device = as.factor(device)
) %>%
filter(!is.na(active_users), active_users > 0)       # removes the bad "Active users" row
tri2 <- tri %>%
filter(step != "4. Click Training") %>%
tidyr::uncount(weights = active_users)               # <-- MUST be weights=
tri2 %>%
select(step, device) %>%
tbl_cross(row = step, col = device, percent = "row") %>%
add_p(test = "fisher.test")
