library(tidyverse)
library(gtsummary)
tri2 <- tri %>%
mutate(active_users = as.integer(active_users)) %>%
tidyr::uncount(weights = active_users)
tbl <- tri2 %>%
select(step, device) %>%
tbl_cross(
row = step,
col = device,
percent = "row"
) %>%
add_p(test = "chisq.test")
tbl
