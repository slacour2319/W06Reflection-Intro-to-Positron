tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6, show_col_types = FALSE)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
tri <- tri %>%
slice(-1) %>%
filter(device != "Total") %>%
mutate(active_users = as.numeric(active_users))
tri2 <- tri %>%
filter(step != "4. Click Training") %>%
tidyr::uncount(active_users)
tbl <- tri2 %>%
select(step, device) %>%
tbl_cross(
row = step,
col = device,
percent = "row"
) %>%
add_p(test = "chisq.test")
tbl
library(tidyverse)
library(gtsummary)
tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6, show_col_types = FALSE)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
tri <- tri %>%
slice(-1) %>%
filter(device != "Total") %>%
mutate(
active_users = as.numeric(active_users),
completion_rate = as.numeric(completion_rate),
abandon_rate = as.numeric(abandon_rate),
device = as.factor(device),
step = as.factor(step)
)
model <- lm(completion_rate ~ active_users + abandon_rate + device + step, data = tri)
tbl_regression(model)
