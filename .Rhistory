tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6)
library(tidyverse)
library(gtsummary)
tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
tri <- tri %>%
slice(-1) %>%
filter(device != "Total") %>%
mutate(active_users = as.numeric(active_users))
tri %>%
select(step, device, active_users) %>%
tbl_cross(
row = step,
col = device,
weight = active_users,
percent = "row"
) %>%
add_p()
library(tidyverse)
library(gtsummary)
tri <- read_csv("TRI-CRM-TRAININGS.csv", skip = 6)
names(tri) <- c("step","device","active_users","completion_rate","abandonments","abandon_rate")
tri <- tri %>%
slice(-1) %>%
filter(device != "Total") %>%
mutate(active_users = as.numeric(active_users))
